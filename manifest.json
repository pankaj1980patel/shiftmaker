{
    "manifest_version": 3,
    "name": "ShiftMate",
    "version": "1.2.0",
    "description": "Keka attendance companion: clock in/out, timed breaks, scheduled auto clock-in/out, multi-tenant, live 8-hour progress badge.",
    "permissions": [
        "storage",
        "alarms",
        "notifications",
        "tabs",
        "scripting",
        "cookies"
    ],
    "host_permissions": [
        "https://*.keka.com/*"
    ],
    "background": {
        "service_worker": "src/background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "src/popup.html",
        "default_title": "ShiftMate — attendance, breaks & progress"
    },
    "icons": {
        "16": "src/icons/bone-32.png",
        "48": "src/icons/bone-48.png",
        "128": "src/icons/bone-128.png"
    }
}